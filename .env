# File .env local để Docker Compose chạy ngay, không bị lỗi thiếu env_file.
# Khi đưa lên online/VPS, hãy đổi JWT_SECRET, POSTGRES_PASSWORD và thông tin ngân hàng.
POSTGRES_USER=football
POSTGRES_PASSWORD=football
POSTGRES_DB=football_academy
DATABASE_URL="postgresql://football:football@db:5432/football_academy?schema=public"
JWT_SECRET="local-dev-secret-change-before-production"
PORT=5173
NODE_ENV=production
FRONTEND_DIST_PATH=/app/frontend/dist
FRONTEND_URL="http://localhost:5173"
BANK_BIN="970436"
BANK_ACCOUNT="0123456789"
BANK_ACCOUNT_NAME="FOOTBALL ACADEMY"
ZALO_OA_ID=""
ZALO_ACCESS_TOKEN=""
