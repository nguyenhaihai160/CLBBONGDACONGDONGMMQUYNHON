# ===============================
# FOOTBALL ACADEMY MANAGER - WEB ONLINE PRODUCTION
# ===============================
# Copy file này thành .env trên VPS:
# cp .env.production.example .env

# PostgreSQL nội bộ Docker
POSTGRES_USER=football
POSTGRES_PASSWORD=CHANGE_STRONG_DB_PASSWORD_HERE
POSTGRES_DB=football_academy
DATABASE_URL="postgresql://football:CHANGE_STRONG_DB_PASSWORD_HERE@db:5432/football_academy?schema=public"

# Bắt buộc đổi trước khi online
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_64_CHARS"

# App chạy nội bộ trong Docker
PORT=5173
NODE_ENV=production
FRONTEND_DIST_PATH=/app/frontend/dist

# Domain web online của anh
# Ví dụ: https://app.tenclb.com
FRONTEND_URL="https://app.tenclb.com"
APP_DOMAIN="app.tenclb.com"

# Thông tin QR ngân hàng / VietQR demo
BANK_BIN="970436"
BANK_ACCOUNT="0123456789"
BANK_ACCOUNT_NAME="FOOTBALL ACADEMY"

# Zalo OA - nhập khi có token thật
ZALO_OA_ID=""
ZALO_ACCESS_TOKEN=""
ZALO_REFRESH_TOKEN=""
